# ===== Database =====
MONGO_URI=your_mongo_connection_string

# ===== Auth =====
JWT_SECRET=replace_with_a_long_random_string
PORT=5000

# ===== Safepay Payment Gateway =====
# Get credentials from https://getsafepay.com merchant dashboard.
# Use the sandbox keys while developing, production keys when going live.
SAFEPAY_ENVIRONMENT=sandbox                       # sandbox | production
SAFEPAY_BASE_URL=https://sandbox.api.getsafepay.com
SAFEPAY_API_KEY=sec_your_safepay_api_key
SAFEPAY_SECRET_KEY=your_safepay_secret_key
SAFEPAY_WEBHOOK_SECRET=your_safepay_webhook_secret

# Where Safepay should send the user after the hosted checkout completes.
# This deep link is consumed by the Expo app (see app.json scheme).
SAFEPAY_REDIRECT_URL=foodie://payment/callback
SAFEPAY_CANCEL_URL=foodie://payment/cancel
