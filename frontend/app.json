{
  "expo": {
    "name": "foodie",
    "slug": "foodie",
    "scheme": "foodie",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5C518"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodie.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to let you upload restaurant images and menu item photos.",
        "NSPhotoLibraryAddOnlyUsageDescription": "We need permission to save images from your device.",
        "NSCameraUsageDescription": "We need camera access to take photos for your restaurant and menu items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F5C518"
      },
      "package": "com.foodie.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera."
        }
      ],
      "expo-web-browser"
    ]
  }
}
